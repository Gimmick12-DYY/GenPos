# ──────────────────────────────────────────────
# GenPos Backend Environment Variables
# Copy this file to .env for local development
# See DEPLOYMENT.md for production setup
# ──────────────────────────────────────────────

# Database (Railway auto-sets this in production)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/genpos

# Redis (Railway auto-sets this in production)
REDIS_URL=redis://localhost:6379

# Object Storage — MinIO locally, Cloudflare R2 in production
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=genpos-assets

# Authentication
JWT_SECRET=change-me-in-production

# OpenAI
OPENAI_API_KEY=sk-xxx
# Optional second provider (OpenAI-compatible base URL, e.g. DashScope compatible mode)
LLM_SECONDARY_API_KEY=
LLM_SECONDARY_BASE_URL=
LLM_SECONDARY_MODEL=gpt-4o-mini

# Generation jobs (BL-111)
MAX_CONCURRENT_GENERATION_JOBS=10
GENERATION_JOB_TIMEOUT_SECONDS=900

# Temporal — same host for API client and worker (`src.temporal.run_worker`)
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=genpos-tasks

# Set true to enqueue on-demand generation on the Temporal worker (requires worker process)
USE_TEMPORAL_FOR_GENERATION=false

# CORS — set to your Vercel URL in production
CORS_ORIGINS=["http://localhost:3000"]

# Debug mode (set to false in production)
DEBUG=true
